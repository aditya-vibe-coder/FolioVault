{
  "name": "foliovault",
  "private": true,
  "version": "1.0.0",
  "description": "Privacy-first Indian investment portfolio tracker with accurate XIRR, AI portfolio coach, and zero-knowledge encrypted backups.",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
